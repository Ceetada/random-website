# Copy this file to .env.local and change the values before deploying.

# The username and password you use to log in at /login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# A long random string used to sign the login session cookie.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=please-generate-a-long-random-string

# Optional: where the SQLite database file lives (defaults to ./data/blog.db)
# DATABASE_PATH=./data/blog.db
